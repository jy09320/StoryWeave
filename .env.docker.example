# Docker 环境变量示例
# 复制为 .env.docker 后再执行 docker compose up --build -d

POSTGRES_DB=storyweave
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=8080

DATABASE_URL=postgresql://postgres:postgres@db:5432/storyweave
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
